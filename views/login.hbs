<div class="flex justify-center">
    <form class="m-4 flex justify-center w-1/3" action="/authenticate" method="post">
        <fieldset class="fieldset bg-[#242424] rounded-box w-full p-4 flex flex-col gap-2">
            <legend class="fieldset-legend text-lg font-bold mb-4">Login</legend>

            {{#if error}}
                <div role="alert" class="alert alert-error mb-4">
                    <span>{{error}}</span>
                </div>
            {{/if}}

            <div class="grid grid-cols-1 gap-y-3 w-full">
                <label class="label text-gray-400">Email</label>
                <input name="email" type="email" class="input bg-[#121212]" placeholder="Email"/>

                <label class="label text-gray-400">Password</label>
                <input name="password" type="password" class="input bg-[#121212]" placeholder="Password"/>

                <button type="submit" class="btn bg-[#f1c40f] text-lg border-none mt-4">Login</button>

                <div class="w-full flex justify-center">
                    <span class="text-gray-400">Noch nicht registriert? <a href="registrieren" class="text-[#f1c40f]">Hier registrieren</a> </span>
                </div>
            </div>

        </fieldset>
    </form>
</div>

