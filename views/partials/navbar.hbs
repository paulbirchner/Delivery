<nav class="navbar px-6 py-4 relative z-50">
    <div class="flex-1 flex items-center gap-x-12">
        <a class="text-3xl font-bold text-[#f1c40f]" href="/">Delivery</a>

        <div class="flex gap-x-6 font-medium text-sm text-gray-300">
            <a class="hover:text-[#C23616] transition-colors" href="/speisekarte">Speisekarte</a>
            {{#if user}}
                {{#if isAdmin}}
                    <a class="hover:text-[#C23616]" href="/admin/bestellungen">Alle Bestellungen</a>
                {{/if}}
            {{/if}}
        </div>
    </div>



    <div class="flex-none gap-x-4 ml-8 flex items-center">
        {{#if user}}
            <span class="text-sm text-gray-500">Hallo, {{user.firstname}}</span>

            <div class="dropdown dropdown-end">
                <div tabindex="0" role="button" class="btn btn-ghost btn-circle">
                    <div class="indicator">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                        </svg>
                        <span class="badge badge-sm badge-error indicator-item text-white {{#unless totalQuantity}}hidden{{/unless}}">{{totalQuantity}}</span>
                    </div>
                </div>
                <div tabindex="0" class="mt-3 z-[1] card card-compact dropdown-content w-80 border border-gray-700 shadow-xl">
                    <div class="card-body bg-[#242424] rounded-lg">
                        <span class="font-bold text-lg text-white">{{totalQuantity}} Artikel</span>
                        <span class="text-[#f1c40f]">Summe: {{totalSum}}</span>

                        <ul class="max-h-40 overflow-y-auto my-2 space-y-2">
                            {{#each basket}}
                                <li class="flex justify-between text-gray-400 text-xs">
                                    <span>{{this.quantity}}x {{this.name}}</span>
                                    <span>{{this.formattedPrice}}</span>
                                </li>
                            {{/each}}
                        </ul>

                        <div>
                            <a href="/basket/checkout" class="btn bg-[#C23616] hover:bg-[#a02b11] text-white border-none btn-block">Zum Warenkorb</a>
                        </div>
                    </div>
                </div>
            </div>

            <a class="btn btn-sm btn-ghost hover:text-[#C23616]" href="/logout">Logout</a>
        {{else}}
            <div class="space-x-3">
                <a class="text-sm font-semibold hover:text-white text-gray-300 transition-colors" href="/login">Login</a>
                <a class="btn btn-sm bg-[#C23616] hover:bg-[#a02b11] border-none text-white rounded-full px-6" href="/registrieren">Registrieren</a>
            </div>
        {{/if}}
    </div>
</nav>